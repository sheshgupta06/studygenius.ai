# StudyGenius AI — Backend environment example
# Copy this file to .env and fill the values before running locally

# Application
APP_NAME=StudyGenius AI
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true

# Secret & JWT
SECRET_KEY=dev-secret-key-change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database (local SQLite works by default for development)
DATABASE_URL=sqlite+aiosqlite:///./test.db

# ChromaDB (if self-hosted)
CHROMA_HOST=localhost
CHROMA_PORT=8001

# AWS (for S3 storage)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=dev-access-key
AWS_SECRET_ACCESS_KEY=dev-secret-key
AWS_S3_BUCKET_NAME=dev-bucket

# Google/Generative AI / OpenAI keys
GEMINI_API_KEY=
OPENAI_API_KEY=

# CORS
ALLOWED_ORIGINS=["http://localhost:5173", "http://127.0.0.1:5173", "http://localhost:5175", "http://127.0.0.1:5175"]
